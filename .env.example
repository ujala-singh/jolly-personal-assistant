# Jira (optional — leave blank to disable the Jira source)
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
# Sprint custom field id. Default works for most Jira Cloud instances.
JIRA_SPRINT_FIELD=customfield_10020

# Linear (optional — leave blank to disable the Linear source)
# Settings → API → Personal API keys
LINEAR_API_KEY=

# Google Calendar (optional)
# Comma-separated list of private iCal URLs ("Secret address in iCal format").
# Get one from: Google Calendar → Settings → "Settings for my calendars" →
#   click the calendar → "Integrate calendar" → copy "Secret address in iCal format"
# Multiple calendars: GCAL_ICS_URLS=https://...ics,https://...ics
GCAL_ICS_URLS=

# Server
PORT=8765
# Auto-refresh interval in seconds
POLL_SECONDS=300

# GitHub uses the `gh` CLI's existing auth — no token needed here.
# Make sure `gh auth status` is green.
